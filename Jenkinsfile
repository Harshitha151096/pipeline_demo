pipeline{
    agent none 
    stages{
        
        stages{
            stage('Checkout'){
                    steps{
                        echo 'Checking out...'
                    }
                }
        
            stage('Build'){
                steps{
                    echo 'Building...'
                }
            }
            stage('Test'){
                steps{
                    echo 'Testing...'
                }
            }
            stage('Deploy'){
                steps{
                    echo 'Deploying...'
                }
            }
    }   
}